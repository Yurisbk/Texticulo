PORT=8080
# Atlas: use mongodb+srv://... ; caracteres especiais na password devem estar URL-encoded
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=texticulo

JWT_SECRET=change-me-in-production
PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
# Optional: custom short domain for displayed URLs (e.g. txt.io).
# The short domain must DNS-point to this server. Leave empty to use PUBLIC_API_URL.
SHORT_DOMAIN=

# OAuth — Google Cloud Console (OAuth 2.0 Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
